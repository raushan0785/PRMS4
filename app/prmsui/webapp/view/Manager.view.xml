<mvc:View
  controllerName="prmsui.controller.Manager"
  displayBlock="true"
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  xmlns:mvc="sap.ui.core.mvc">

  <Page title="Manager Workspace" class="prmsWorkspacePage sapUiContentPadding">
    <headerContent>
      <ObjectStatus text="{session>/fullName}" state="Information" />
      <Button text="Logout" icon="sap-icon://log" press=".onLogout" />
    </headerContent>

    <content>
      <VBox class="sapUiSmallMargin">
        <Panel headerText="Appraisal Cycle" class="sapUiSmallMarginBottom">
          <VBox>
            <Title text="{view>/cycleText}" level="H4" />

            <Select
              selectedKey="{view>/selectedYear}"
              change=".onYearChange"
              items="{view>/years}"
              width="14rem"
              class="sapUiTinyMarginTop">
              <core:Item key="{view>}" text="{view>}" />
            </Select>
          </VBox>
        </Panel>

        <Panel headerText="Team Members" class="sapUiSmallMarginBottom">
          <List items="{view>/teamMembers}">
            <StandardListItem
              title="{view>name}"
              description="{view>role}"
              type="Active"
              press=".onTeamMemberPress" />
          </List>
        </Panel>

        <Panel
          headerText="{= ${view>/selectedEmployeeName} ? 'Selected Employee: ' + ${view>/selectedEmployeeName} : 'Select Employee' }"
          class="sapUiSmallMarginBottom"
          visible="{= !!${view>/selectedEmployeeId} }">

          <Toolbar>
            <Button
              text="Company OKRs"
              icon="sap-icon://target-group"
              type="{= ${view>/selectedManagerSection} === 'okrs' ? 'Emphasized' : 'Default' }"
              press=".onManagerSectionSelect">
              <customData>
                <core:CustomData key="section" value="okrs" />
              </customData>
            </Button>

            <Button
              text="Employee Goals"
              icon="sap-icon://activity-items"
              type="{= ${view>/selectedManagerSection} === 'goals' ? 'Emphasized' : 'Default' }"
              press=".onManagerSectionSelect">
              <customData>
                <core:CustomData key="section" value="goals" />
              </customData>
            </Button>

            <Button
              text="Employee Check-Ins"
              icon="sap-icon://discussion"
              type="{= ${view>/selectedManagerSection} === 'checkins' ? 'Emphasized' : 'Default' }"
              press=".onManagerSectionSelect">
              <customData>
                <core:CustomData key="section" value="checkins" />
              </customData>
            </Button>

            <Button
              text="Year-End Assessment"
              icon="sap-icon://performance"
              type="{= ${view>/selectedManagerSection} === 'assessment' ? 'Emphasized' : 'Default' }"
              press=".onManagerSectionSelect">
              <customData>
                <core:CustomData key="section" value="assessment" />
              </customData>
            </Button>
          </Toolbar>
        </Panel>

        <Panel
          headerText="Company OKRs"
          class="sapUiSmallMarginBottom"
          visible="{= ${view>/selectedManagerSection} === 'okrs' &amp;&amp; !!${view>/selectedEmployeeId} }">
          <Table items="{view>/okrs}">
            <columns>
              <Column><Text text="Title" /></Column>
              <Column><Text text="Description" /></Column>
              <Column><Text text="Year / Quarter" /></Column>
            </columns>

            <items>
              <ColumnListItem>
                <cells>
                  <Text text="{view>title}" />
                  <Text text="{view>description}" wrapping="true" />
                  <Text text="{view>cycleText}" />
                </cells>
              </ColumnListItem>
            </items>
          </Table>
        </Panel>

        <Panel
          headerText="Employee Goals"
          class="sapUiSmallMarginBottom"
          visible="{= ${view>/selectedManagerSection} === 'goals' &amp;&amp; !!${view>/selectedEmployeeId} }">
          <Table items="{view>/selectedTeamGoals}">
            <columns>
              <Column><Text text="Employee" /></Column>
              <Column><Text text="Goal" /></Column>
              <Column><Text text="Cycle" /></Column>
              <Column><Text text="Start Date" /></Column>
              <Column><Text text="End Date" /></Column>
              <Column><Text text="Type" /></Column>
              <Column><Text text="Status" /></Column>
              <Column><Text text="Submission" /></Column>
              <Column><Text text="Manager Comment" /></Column>
              <Column><Text text="Quarter Check-In" /></Column>
              <Column><Text text="Actions" /></Column>
            </columns>

            <items>
              <ColumnListItem>
                <cells>
                  <Text text="{view>employeeName}" />
                  <Text text="{view>title}" />
                  <Text text="{view>cycleText}" />
                  <Text text="{view>startDate}" />
                  <Text text="{view>endDate}" />
                  <Text text="{view>type}" />
                  <Text text="{= ${view>progress} + '% / ' + ${view>status} }" />

                  <ObjectStatus
                    text="{view>submissionStatus}"
                    state="{= ${view>submissionStatus} === 'Approved' ? 'Success' : ${view>submissionStatus} === 'Rejected' ? 'Error' : 'Information' }" />

                  <Input value="{view>managerComment}" placeholder="Add approval or rejection note" />

                  <Button
                    text="{= ${view>checkInClosed} ? 'Closed' : 'Close Check-In' }"
                    press=".onCloseGoalCheckIn"
                    enabled="{= !${view>checkInClosed} }" />

                  <HBox>
                    <Button text="Approve" icon="sap-icon://accept" press=".onApproveGoal" enabled="{= ${view>submissionStatus} === 'Submitted' || ${view>submissionStatus} === 'Rejected' }" />
                    <Button text="Reject" icon="sap-icon://decline" press=".onRejectGoal" class="sapUiTinyMarginBegin" enabled="{= ${view>submissionStatus} === 'Submitted' || ${view>submissionStatus} === 'Approved' }" />
                  </HBox>
                </cells>
              </ColumnListItem>
            </items>
          </Table>
        </Panel>

        <Panel
          headerText="Employee Check-Ins"
          class="sapUiSmallMarginBottom"
          visible="{= ${view>/selectedManagerSection} === 'checkins' &amp;&amp; !!${view>/selectedEmployeeId} }">
          <Table items="{view>/selectedTeamCheckIns}">
            <columns>
              <Column><Text text="Employee" /></Column>
              <Column><Text text="Goal" /></Column>
              <Column><Text text="Focus Area" /></Column>
              <Column><Text text="Progress" /></Column>
              <Column><Text text="Employee Notes" /></Column>
              <Column><Text text="Manager Comment" /></Column>
              <Column><Text text="Save" /></Column>
            </columns>

            <items>
              <ColumnListItem>
                <cells>
                  <Text text="{view>employeeName}" />
                  <Text text="{view>goalTitle}" />
                  <Text text="{view>focusArea}" />
                  <Text text="{= ${view>progress} + '%' }" />
                  <Text text="{view>notes}" wrapping="true" />
                  <TextArea value="{view>comments}" rows="2" />
                  <Button text="Save Comment" press=".onSaveCheckInComment" />
                </cells>
              </ColumnListItem>
            </items>
          </Table>
        </Panel>

        <Panel
          headerText="Year-End Assessment"
          visible="{= ${view>/selectedManagerSection} === 'assessment' &amp;&amp; !!${view>/selectedEmployeeId} }">
          <Toolbar>
            <Title text="Overall Final Rating" level="H4" />
            <RatingIndicator
              value="{view>/overallFinalRating}"
              maxValue="5" />
            <Text text="Rating is based on all manager goal ratings." class="sapUiTinyMarginBegin" />
            <ToolbarSpacer />
            <Button
              text="Submit Overall Final Rating"
              icon="sap-icon://complete"
              type="Emphasized"
              enabled="{view>/canFinalizeOverall}"
              press=".onFinalizeOverallAssessment" />
          </Toolbar>

          <Table items="{view>/selectedAssessments}">
            <columns>
              <Column><Text text="Employee" /></Column>
              <Column><Text text="Goal" /></Column>
              <Column><Text text="Status" /></Column>
              <Column><Text text="Self Rating" /></Column>
              <Column><Text text="Manager Rating" /></Column>
              <Column><Text text="Manager Comment" /></Column>
            </columns>

            <items>
              <ColumnListItem>
                <cells>
                  <Text text="{view>employeeName}" />
                  <Text text="{view>goalTitle}" />
                  <ObjectStatus
                    text="{view>finalStatus}"
                    state="{= ${view>finalStatus} === 'Finalized' ? 'Success' : 'Information' }" />
                  <Text text="{view>latestSelfRatingLabel}" />

                  <RatingIndicator
                    value="{view>managerRating}"
                    maxValue="5"
                    change=".onManagerRatingChange"
                    enabled="{= ${view>finalStatus} !== 'Finalized' }" />

                  <TextArea
                    value="{view>managerComments}"
                    rows="2"
                    placeholder="Add manager comment"
                    enabled="{= ${view>finalStatus} !== 'Finalized' }" />
                </cells>
              </ColumnListItem>
            </items>
          </Table>
        </Panel>
      </VBox>
    </content>
  </Page>
</mvc:View>
