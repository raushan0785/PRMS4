<mvc:View
  controllerName="prmsui.controller.Manager"
  displayBlock="true"
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  xmlns:mvc="sap.ui.core.mvc">
  <Page title="Manager Workspace" class="sapUiContentPadding">
    <headerContent>
      <ObjectStatus text="{session>/fullName}" state="Information" />
      <Button text="Logout" press=".onLogout" />
    </headerContent>
    <content>
      <VBox class="sapUiSmallMargin">
        <Panel headerText="Appraisal Cycle" class="sapUiSmallMarginBottom">
          <VBox>
            <Title text="{view>/cycleText}" level="H4" />
            <Select selectedKey="{view>/selectedCycleId}" change=".onCycleChange" items="{view>/cycles}" width="14rem" class="sapUiTinyMarginTop">
              <core:Item key="{view>ID}" text="{= ${view>year} + ' - ' + ${view>quarter} }" />
            </Select>
          </VBox>
        </Panel>

        <Panel headerText="Team Members" class="sapUiSmallMarginBottom">
          <List items="{view>/teamMembers}">
            <StandardListItem title="{view>name}" description="{view>role}" />
          </List>
        </Panel>

        <Panel headerText="Company OKRs" class="sapUiSmallMarginBottom">
          <Table items="{view>/okrs}">
          
<columns>
  <Column><Text text="Title" /></Column>
  <Column><Text text="Description" /></Column>
  <Column><Text text="Year / Quarter" /></Column>
</columns>


            <items>
              <ColumnListItem>
              
<cells>
  <Text text="{view>title}" />
  <Text text="{view>description}" wrapping="true" />
  <Text text="{view>cycleText}" />
</cells>


              </ColumnListItem>
            </items>
          </Table>
        </Panel>

        <Panel headerText="Employee Goals" class="sapUiSmallMarginBottom">
          <Table items="{view>/teamGoals}">
            <columns>
              <Column><Text text="Employee" /></Column>
              <Column><Text text="Goal" /></Column>
              <Column><Text text="Cycle" /></Column>
              <Column><Text text="Type" /></Column>
              <Column><Text text="Status" /></Column>
              <Column><Text text="Submission" /></Column>
              <Column><Text text="Manager Comment" /></Column>
              <Column><Text text="Actions" /></Column>
            </columns>
            <items>
              <ColumnListItem>
                <cells>
                  <Text text="{view>employeeName}" />
                  <Text text="{view>title}" />
                  <Text text="{= ${view>cycle_ID} ? ${view>/cycleText} : '' }" />
                  <Text text="{view>type}" />
                  <Text text="{= ${view>progress} + '% / ' + ${view>status} }" />
                  <ObjectStatus text="{view>submissionStatus}" state="{= ${view>submissionStatus} === 'Approved' ? 'Success' : ${view>submissionStatus} === 'Rejected' ? 'Error' : 'Information' }" />
                  <Input value="{view>managerComment}" placeholder="Add approval or rejection note" />
                  <HBox>
                    <Button text="Approve" press=".onApproveGoal" enabled="{= ${view>submissionStatus} === 'Submitted' || ${view>submissionStatus} === 'Rejected' }" />
                    <Button text="Reject" press=".onRejectGoal" class="sapUiTinyMarginBegin" enabled="{= ${view>submissionStatus} === 'Submitted' || ${view>submissionStatus} === 'Approved' }" />
                  </HBox>
                </cells>
              </ColumnListItem>
            </items>
          </Table>
        </Panel>

        <Panel headerText="Employee Check-Ins" class="sapUiSmallMarginBottom">
          <Table items="{view>/teamCheckIns}">
            <columns>
              <Column><Text text="Employee" /></Column>
              <Column><Text text="Goal" /></Column>
              <Column><Text text="Focus Area" /></Column>
              <Column><Text text="Self Rating" /></Column>
              <Column><Text text="Progress" /></Column>
              <Column><Text text="Employee Notes" /></Column>
              <Column><Text text="Manager Comment" /></Column>
              <Column><Text text="Save" /></Column>
            </columns>
            <items>
              <ColumnListItem>
                <cells>
                  <Text text="{view>employeeName}" />
                  <Text text="{view>goalTitle}" />
                  <Text text="{view>focusArea}" />
                  <Text text="{view>selfRatingLabel}" />
                  <Text text="{= ${view>progress} + '%' }" />
                  <Text text="{view>notes}" wrapping="true" />
                  <TextArea value="{view>comments}" rows="2" />
                  <Button text="Save Comment" press=".onSaveCheckInComment" />
                </cells>
              </ColumnListItem>
            </items>
          </Table>
        </Panel>

        <Panel headerText="Self-Assessment Review &amp; Final Rating">
          <Table items="{view>/assessments}">
            <columns>
              <Column><Text text="Employee" /></Column>
              <Column><Text text="Self Rating" /></Column>
              <Column><Text text="Manager Rating" /></Column>
            
              <Column><Text text="Manager Feedback" /></Column>
              <Column><Text text="Status" /></Column>
              <Column><Text text="Actions" /></Column>
            </columns>
            <items>
              <ColumnListItem>
                <cells>
                  <Text text="{view>employeeName}" />
                  <Text text="{= ${view>latestCheckInSelfRatingLabel} || ${view>selfRating} }" />
                  <RatingIndicator value="{view>managerRating}" maxValue="5" change=".onManagerRatingChange" enabled="{= ${view>finalStatus} !== 'Finalized' }" />
                 
                  <TextArea value="{view>managerComments}" rows="2" enabled="{= ${view>finalStatus} !== 'Finalized' }" />
                  <ObjectStatus text="{view>finalStatus}" state="{= ${view>finalStatus} === 'Finalized' ? 'Success' : 'Information' }" />
                  <HBox>
                    <Button text="Save Feedback" press=".onSaveAssessmentFeedback" enabled="{= ${view>finalStatus} !== 'Finalized' }" />
                    <Button text="Final Submit" press=".onFinalizeAssessment" class="sapUiTinyMarginBegin" enabled="{= ${view>finalStatus} !== 'Finalized' }" />
                  </HBox>
                </cells>
              </ColumnListItem>
            </items>
          </Table>
        </Panel>
      </VBox>
    </content>
  </Page>
</mvc:View>
