
<mvc:View
  controllerName="prmsui.controller.Login"
  displayBlock="true"
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  xmlns:mvc="sap.ui.core.mvc">

  <Page showHeader="false" class="prmsLoginPage">
    <content>

      <FlexBox alignItems="Center" justifyContent="Center" height="100%">

        <VBox class="prmsLoginShell" renderType="Bare">

          <HBox alignItems="Center" class="sapUiSmallMarginBottom">
            <core:Icon
              src="sap-icon://employee"
              size="2rem"
              class="sapUiTinyMarginEnd" />

            <VBox>
             <Title text="PRMS Login" level="H2" />
<Text text="Performance &amp; Review Management System" />
            </VBox>
          </HBox>

          <Panel class="prmsLoginCard" headerText="Sign In">

            <VBox class="sapUiMediumMargin">

              <Text
                text="Use your company email ID to receive OTP and access your dashboard."
                class="sapUiSmallMarginBottom" />

              <!-- Email -->
              <Label text="Company Email ID" />
              <Input
                value="{login>/emailId}"
                placeholder="Enter email ID"
                width="100%"
                class="sapUiTinyMarginBottom" />

              <!-- Send OTP -->
              <Button
                text="Send OTP"
                press=".onSendOTP"
                width="100%"
                class="sapUiTinyMarginBottom" />

              <!-- OTP -->
              <Label text="Enter OTP" />
              <Input
                value="{login>/otp}"
                placeholder="Enter OTP"
                width="100%"
                class="sapUiTinyMarginBottom" />

              <!-- Login -->
             <Button text="Verify &amp; Login" type="Emphasized" press=".onLogin" class="sapUiSmallMarginTop" width="100%" />

              <!-- Info -->
              <MessageStrip
                class="sapUiMediumMarginTop"
                type="Information"
                showIcon="true"
                text="Only email IDs ending with @sumodigitech.com are allowed." />

            </VBox>

          </Panel>

        </VBox>

      </FlexBox>

    </content>
  </Page>

</mvc:View>

