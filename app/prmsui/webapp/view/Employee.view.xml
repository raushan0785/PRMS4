<mvc:View
  controllerName="prmsui.controller.Employee"
  displayBlock="true"
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  xmlns:form="sap.ui.layout.form"
  xmlns:mvc="sap.ui.core.mvc">

  <Page title="Employee Workspace" class="prmsWorkspacePage sapUiContentPadding">
    <headerContent>
      <ObjectStatus text="{session>/fullName}" state="Information" />
      <Button text="Logout" icon="sap-icon://log" press=".onLogout" />
    </headerContent>

    <content>
      <VBox class="sapUiSmallMargin">

        <Panel
          headerText="Appraisal Cycle"
          expandable="true"
          expanded="true"
          class="sapUiSmallMarginBottom">
          <HBox justifyContent="SpaceBetween" wrap="Wrap">
            <VBox>
              <Title text="{view>/cycleText}" level="H4" />

              <Select
                selectedKey="{view>/selectedYear}"
                change=".onYearChange"
                items="{view>/years}"
                width="14rem"
                class="sapUiTinyMarginTop">
                <core:Item key="{view>}" text="{view>}" />
              </Select>

              <Text text="{= 'Goal window: ' + (${view>/stats/canEditGoals} ? 'Open' : 'Closed') }" />
              <Text text="{= 'Quarterly check-in window: ' + (${view>/stats/canEditCheckIns} ? 'Open' : 'Closed') }" />
            </VBox>

            <VBox>
              <Text text="{= 'Manager: ' + ${view>/managerName} }" />
              <Text text="{= 'Cycle status: ' + (${view>/cycle/status} || 'N/A') }" />
            </VBox>
          </HBox>

          <Toolbar class="sapUiSmallMarginTop">
              <Button
              text="Company OKRs"
              icon="sap-icon://target-group"
              type="{= ${view>/selectedEmployeeSection} === 'okrs' ? 'Emphasized' : 'Default' }"
              press=".onEmployeeSectionSelect">
              <customData>
                <core:CustomData key="section" value="okrs" />
              </customData>
            </Button>

            <Button
              text="Manage Goals"
              icon="sap-icon://add-activity"
              type="{= ${view>/selectedEmployeeSection} === 'manageGoals' ? 'Emphasized' : 'Default' }"
              press=".onEmployeeSectionSelect">
              <customData>
                <core:CustomData key="section" value="manageGoals" />
              </customData>
            </Button>

            <Button
              text="Year-End Assessment"
              icon="sap-icon://performance"
              enabled="{= ${view>/stats/canSubmitYearEnd} || ${view>/stats/canResubmitYearEnd} || ${view>/stats/hasAssessment} }"
              type="{= ${view>/selectedEmployeeSection} === 'yearEnd' ? 'Emphasized' : 'Default' }"
              press=".onEmployeeSectionSelect">
              <customData>
                <core:CustomData key="section" value="yearEnd" />
              </customData>
            </Button>
          </Toolbar>
        </Panel>

        <Panel
          headerText="Company OKRs"
          expandable="true"
          expanded="true"
          class="sapUiSmallMarginBottom"
          visible="{= ${view>/selectedEmployeeSection} === 'okrs' }">
          <Table items="{view>/okrs}">
            <columns>
              <Column><Text text="Title" /></Column>
              <Column><Text text="Description" /></Column>
              <Column><Text text="Year" /></Column>
            </columns>

            <items>
              <ColumnListItem>
                <cells>
                  <Text text="{view>title}" />
                  <Text text="{view>description}" wrapping="true" />
                  <Text text="{view>cycleText}" />
                </cells>
              </ColumnListItem>
            </items>
          </Table>
        </Panel>

        <Panel
          headerText="Manage Goals"
          expandable="true"
          expanded="true"
          class="sapUiSmallMarginBottom"
          visible="{= ${view>/selectedEmployeeSection} === 'manageGoals' }">
          <Toolbar>
            <Button
              text="Performance Goal"
              icon="sap-icon://business-objects-experience"
              type="{= ${view>/selectedGoalType} === 'Performance' ? 'Emphasized' : 'Default' }"
              press=".onGoalTypeSelect">
              <customData>
                <core:CustomData key="goalType" value="Performance" />
              </customData>
            </Button>

            <Button
              text="Development Goal"
              icon="sap-icon://learning-assistant"
              type="{= ${view>/selectedGoalType} === 'Development' ? 'Emphasized' : 'Default' }"
              press=".onGoalTypeSelect">
              <customData>
                <core:CustomData key="goalType" value="Development" />
              </customData>
            </Button>
          </Toolbar>

          <Toolbar visible="{= !!${view>/selectedGoalType} &amp;&amp; ${view>/selectedGoalAction} !== 'checkin' }" class="sapUiSmallMarginTop">
            <Title text="{= ${view>/selectedGoalType} + ' Goals' }" level="H4" />
            <ToolbarSpacer />
            <Button
              text="Create Goal"
              icon="sap-icon://add"
              type="Emphasized"
              press=".onGoalActionSelect">
              <customData>
                <core:CustomData key="goalAction" value="create" />
              </customData>
            </Button>
          </Toolbar>

          <Panel
            headerText="Create Goal"
            expandable="true"
            expanded="true"
            visible="{= ${view>/selectedGoalAction} === 'create' }"
            class="sapUiSmallMarginTop">
            <form:SimpleForm editable="true" layout="ResponsiveGridLayout">
              <Label text="Goal Title" />
              <Input value="{view>/goalDraft/title}" enabled="{view>/stats/canEditGoals}" />

              <Label text="Description" />
              <TextArea value="{view>/goalDraft/description}" rows="2" enabled="{view>/stats/canEditGoals}" />

              <Label text="OKR Mapping" visible="{= ${view>/selectedGoalType} === 'Performance' }" />
              <Select
                selectedKey="{view>/goalDraft/okr_ID}"
                items="{view>/okrs}"
                enabled="{view>/stats/canEditGoals}"
                visible="{= ${view>/selectedGoalType} === 'Performance' }">
                <core:Item key="{view>ID}" text="{view>title}" />
              </Select>

              <Label text="Start Date" />
              <DatePicker
                value="{view>/goalDraft/startDate}"
                valueFormat="yyyy-MM-dd"
                displayFormat="medium"
                enabled="{view>/stats/canEditGoals}" />

              <Label text="End Date" />
              <DatePicker
                value="{view>/goalDraft/endDate}"
                valueFormat="yyyy-MM-dd"
                displayFormat="medium"
                enabled="{view>/stats/canEditGoals}" />

              <Label text="Quarter" />
              <Select selectedKey="{view>/goalDraft/quarter}" enabled="{view>/stats/canEditGoals}">
                <core:Item key="Q1" text="Q1" />
                <core:Item key="Q2" text="Q2" />
                <core:Item key="Q3" text="Q3" />
                <core:Item key="Q4" text="Q4" />
              </Select>
            </form:SimpleForm>

            <Toolbar>
              <Button text="Create Goal" type="Emphasized" press=".onCreateGoal" enabled="{view>/stats/canEditGoals}" />
              <ToolbarSpacer />
              <Button text="Submit Goals To Manager" press=".onSubmitGoalsForApproval" enabled="{view>/stats/canEditGoals}" />
            </Toolbar>
          </Panel>

          <Panel
            headerText="Quarterly Check-In"
            expandable="true"
            expanded="true"
            visible="{= ${view>/selectedGoalAction} === 'checkin' }"
            class="sapUiSmallMarginTop">
            <form:SimpleForm editable="true" layout="ResponsiveGridLayout">
              <Label text="Goal" />
              <Select selectedKey="{view>/checkInDraft/goal_ID}" items="{view>/checkInEligibleGoals}" enabled="{view>/stats/canEditCheckIns}">
                <core:Item key="{view>ID}" text="{view>title}" />
              </Select>

              <Label text="Progress" />
              <StepInput value="{view>/checkInDraft/progress}" min="0" max="100" enabled="{view>/stats/canEditCheckIns}" />

              <Label text="Status" />
              <Select selectedKey="{view>/checkInDraft/status}" enabled="{view>/stats/canEditCheckIns}">
                <core:Item key="Open" text="Open" />
                <core:Item key="In Progress" text="In Progress" />
                <core:Item key="Completed" text="Completed" />
              </Select>

              <Label text="Focus Area" />
              <Select selectedKey="{view>/checkInDraft/focusArea}" enabled="{view>/stats/canEditCheckIns}">
                <core:Item key="Delivery" text="Delivery" />
                <core:Item key="Collaboration" text="Collaboration" />
                <core:Item key="Learning" text="Learning" />
                <core:Item key="Quality" text="Quality" />
              </Select>

              <Label text="Achievements / Challenges" />
              <TextArea value="{view>/checkInDraft/notes}" rows="3" enabled="{view>/stats/canEditCheckIns}" />
            </form:SimpleForm>

            <Toolbar>
              <Button text="Submit Update To Manager" type="Emphasized" press=".onAddCheckIn" enabled="{view>/stats/canEditCheckIns}" />
            </Toolbar>
          </Panel>

          <Panel
            headerText="Goal History"
            expandable="true"
            expanded="true"
            visible="{= !!${view>/selectedGoalType} &amp;&amp; ${view>/selectedGoalAction} !== 'checkin' }"
            class="sapUiSmallMarginTop">
            <ScrollContainer height="16rem" vertical="true" horizontal="true" class="sapUiTinyMarginTop">
              <Table items="{view>/filteredGoals}">
                <columns>
                  <Column><Text text="Title" /></Column>
                  <Column><Text text="Quarter" /></Column>
                  <Column><Text text="Start Date" /></Column>
                  <Column><Text text="End Date" /></Column>
                  <Column><Text text="Type" /></Column>
                  <Column><Text text="Approval" /></Column>
                  <Column><Text text="Manager Comment" /></Column>
                  <Column><Text text="Quarterly Check-In" /></Column>
                </columns>

                <items>
                  <ColumnListItem>
                    <cells>
                      <Text text="{view>title}" />
                      <Text text="{view>quarter}" />
                      <Text text="{view>startDate}" />
                      <Text text="{view>endDate}" />
                      <Text text="{view>type}" />

                      <ObjectStatus
                        text="{view>submissionStatus}"
                        state="{= ${view>submissionStatus} === 'Approved' ? 'Success' : ${view>submissionStatus} === 'Rejected' ? 'Error' : 'Information' }" />

                      <Text text="{view>managerComment}" wrapping="true" />
                      <Button
                        text="Quarterly Check-In"
                        icon="sap-icon://activity-individual"
                        press=".onStartGoalCheckIn"
                        enabled="{= ${view>submissionStatus} === 'Approved' &amp;&amp; !${view>checkInClosed} }" />
                    </cells>
                  </ColumnListItem>
                </items>
              </Table>
            </ScrollContainer>
          </Panel>

          <Panel
            headerText="Quarterly Check-In History"
            expandable="true"
            expanded="true"
            visible="{= ${view>/selectedGoalAction} === 'checkin' }"
            class="sapUiSmallMarginTop">
            <Title text="{= ${view>/selectedGoalType} + ' Quarterly Check-In History' }" level="H4" />
            <ScrollContainer height="16rem" vertical="true" horizontal="true" class="sapUiTinyMarginTop">
              <Table items="{view>/filteredCheckIns}">
                <columns>
                  <Column><Text text="Goal" /></Column>
                  <Column><Text text="Quarter" /></Column>
                  <Column><Text text="Focus Area" /></Column>
                  <Column><Text text="Progress" /></Column>
                  <Column><Text text="Your Update" /></Column>
                  <Column><Text text="Manager Comment" /></Column>
                </columns>

                <items>
                  <ColumnListItem>
                    <cells>
                      <Text text="{view>goalTitle}" />
                      <Text text="{view>quarter}" />
                      <Text text="{view>focusArea}" />
                      <Text text="{= ${view>progress} + '%' }" />
                      <Text text="{view>notes}" wrapping="true" />
                      <Text text="{view>comments}" wrapping="true" />
                    </cells>
                  </ColumnListItem>
                </items>
              </Table>
            </ScrollContainer>
          </Panel>
        </Panel>

        <Panel
          headerText="Year-End Assessment"
          expandable="true"
          expanded="true"
          class="sapUiSmallMarginBottom"
          visible="{= ${view>/selectedEmployeeSection} === 'yearEnd' }">
          <form:SimpleForm editable="true" layout="ResponsiveGridLayout">
            <Label text="Goal" />
            <Select
              selectedKey="{view>/yearEndDraft/goal_ID}"
              items="{view>/goals}"
              change=".onYearEndGoalChange"
              enabled="{= ${view>/stats/canSubmitYearEnd} || ${view>/stats/canResubmitYearEnd} }">
              <core:Item key="{view>ID}" text="{view>title}" />
            </Select>

            <Label text="Status" />
            <ObjectStatus
              text="{view>/yearEndDraft/status}"
              state="{= ${view>/yearEndDraft/status} === 'Finalized' ? 'Success' : 'Information' }" />

            <Label text="Self Rating" />
            <Select
              selectedKey="{view>/yearEndDraft/selfRating}"
              enabled="{= ${view>/stats/canSubmitYearEnd} || ${view>/stats/canResubmitYearEnd} }">
              <core:Item key="1" text="1 - Too New to Assess" />
              <core:Item key="2" text="2 - Needs Improvement" />
              <core:Item key="3" text="3 - Meets Expectations" />
              <core:Item key="4" text="4 - Exceeds Expectations" />
              <core:Item key="5" text="5 - Outstanding" />
            </Select>

            <Label text="Manager Rating" />
            <ObjectStatus
              text="{= ${view>/yearEndDraft/managerRating} ? ${view>/yearEndDraft/managerRating} + '/5' : 'Pending' }"
              state="{= ${view>/yearEndDraft/managerRating} ? 'Information' : 'Warning' }" />

            <Label text="Overall Final Rating" />
            <ObjectStatus
              text="{= ${view>/overallFinalStatus} === 'Finalized' &amp;&amp; ${view>/overallFinalRating} ? ${view>/overallFinalRating} + '/5' : 'Pending' }"
              state="{= ${view>/overallFinalStatus} === 'Finalized' ? 'Success' : 'Warning' }" />

            <Label text="Manager Comment" />
            <Text text="{= ${view>/yearEndDraft/managerComments} || 'Pending' }" wrapping="true" />
          </form:SimpleForm>

          <Toolbar>
            <Button
              text="{= ${view>/stats/canResubmitYearEnd} ? 'Resubmit Year-End Assessment' : 'Submit Year-End Assessment' }"
              icon="sap-icon://paper-plane"
              type="Emphasized"
              press=".onSubmitYearEndAssessment"
              enabled="{= ${view>/stats/canSubmitYearEnd} || ${view>/stats/canResubmitYearEnd} }" />
          </Toolbar>

          <Table items="{view>/assessments}" class="sapUiSmallMarginTop">
            <columns>
              <Column><Text text="Goal" /></Column>
              <Column><Text text="Status" /></Column>
              <Column><Text text="Self Rating" /></Column>
              <Column><Text text="Manager Rating" /></Column>
              <Column><Text text="Manager Comment" /></Column>
            </columns>

            <items>
              <ColumnListItem>
                <cells>
                  <Text text="{view>goalTitle}" />
                  <ObjectStatus
                    text="{view>finalStatus}"
                    state="{= ${view>finalStatus} === 'Finalized' ? 'Success' : 'Information' }" />
                  <Text text="{view>latestSelfRatingLabel}" />
                  <Text text="{view>managerRatingText}" />
                  <Text text="{view>managerCommentText}" wrapping="true" />
                </cells>
              </ColumnListItem>
            </items>
          </Table>
        </Panel>

      </VBox>
    </content>
  </Page>
</mvc:View>
